---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import { getCollection, render } from 'astro:content';

const risorse = (await getCollection('risorse')).sort((a, b) =>
  b.data.date.getTime() - a.data.date.getTime()
);

const typeColors: Record<string, string> = {
  PDF: '#1A305E',
  Audio: '#C9A86B',
  Video: '#B22222',
  Worksheet: '#1A305E',
  Esercizio: '#B22222',
  Guida: '#C9A86B',
};
---

<BaseLayout title="Risorse Didattiche" description="Strumenti pratici per sbloccare il tuo inglese: PDF, esercizi, guide e materiali audio-video firmati Martina Staltari.">
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <p class="section-label">Materiali gratuiti</p>
      <h1>Risorse Didattiche</h1>
      <p class="page-subtitle">Strumenti concreti che puoi usare subito per sbloccare il tuo inglese.</p>
    </div>
  </section>

  <section class="section risorse-section">
    <div class="container">
      {risorse.length === 0 ? (
        <p class="empty-state">Le prime risorse sono in preparazione. Torna presto!</p>
      ) : (
        <div class="risorse-grid">
          {risorse.map(async (risorsa) => {
            const { Content } = await render(risorsa);
            return (
              <div class="risorsa-card">
                <div class="risorsa-header">
                  <span class="risorsa-type" style={`background-color: ${typeColors[risorsa.data.type] ?? '#1A305E'}`}>
                    {risorsa.data.type}
                  </span>
                  <span class="risorsa-level">{risorsa.data.level}</span>
                  {risorsa.data.free && <span class="risorsa-free">Gratuito</span>}
                </div>
                <h2>{risorsa.data.title}</h2>
                <p class="risorsa-desc">{risorsa.data.description}</p>
                <div class="risorsa-body"><Content /></div>
              </div>
            );
          })}
        </div>
      )}

      <div class="risorse-cta">
        <p>Vuoi una sessione personalizzata?</p>
        <Button href="/contatti#calendly">Prenota una chiamata gratuita</Button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-hero {
    background-color: var(--color-navy);
    padding-block: 6.5rem 4rem;
    position: relative;
    overflow: hidden;
  }
  .page-hero::after {
    content: '✎';
    position: absolute;
    right: 5%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-heading);
    font-size: clamp(10rem, 18vw, 20rem);
    color: rgba(255, 255, 255, 0.03);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }
  .page-hero h1 {
    color: var(--color-cloud);
    margin-bottom: 1rem;
  }
  .section-label {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  .page-subtitle {
    color: rgba(248, 249, 251, 0.75);
    font-size: 1.15rem;
    max-width: 50ch;
    line-height: 1.8;
  }
  .risorse-section {
    background-color: var(--color-cloud);
  }
  .risorse-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }
  .risorsa-card {
    background-color: var(--color-sand);
    border: 1px solid var(--color-sand);
    border-radius: 4px;
    padding: 2.5rem;
    transition: var(--transition-base);
    display: flex;
    flex-direction: column;
  }
  .risorsa-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(26, 48, 94, 0.1);
    border-color: var(--color-navy);
  }
  .risorsa-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .risorsa-type {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-white);
    padding: 0.25rem 0.8rem;
    border-radius: 2px;
  }
  .risorsa-level {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-navy);
    border: 1px solid rgba(26, 48, 94, 0.15);
    padding: 0.18rem 0.6rem;
    border-radius: 2px;
  }
  .risorsa-free {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-white);
    background-color: var(--color-red);
    padding: 0.25rem 0.7rem;
    border-radius: 2px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .risorsa-card h2 {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
    color: var(--color-navy);
  }
  .risorsa-desc {
    font-size: 0.92rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    color: var(--color-navy);
  }
  .risorsa-body {
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--color-navy);
    opacity: 0.8;
  }
  .risorse-cta {
    margin-top: 5rem;
    text-align: center;
    padding: 4rem;
    background-color: var(--color-sand);
    border-radius: 4px;
    border: 1px solid rgba(26, 48, 94, 0.05);
  }
  .risorse-cta p {
    font-family: var(--font-quote);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--color-navy);
    margin-bottom: 2rem;
    max-width: none;
  }
  .empty-state {
    text-align: center;
    font-family: var(--font-quote);
    font-size: 1.3rem;
    font-style: italic;
    color: var(--color-navy);
    opacity: 0.5;
    padding: 5rem 0;
  }
</style>
